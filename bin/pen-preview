#!/bin/bash
# pen-preview — PDF preview of .pen files in cmux browser
# Works with the PostToolUse hook to auto-export and reload after batch_design.
#
# Requirements: cmux (https://github.com/manaflow-ai/cmux)
# Platform: macOS

BASE_DIR="/tmp/pen-preview-${USER:-$(id -u)}"

if [ -z "$BASE_DIR" ] || [ "$BASE_DIR" = "/tmp/pen-preview-" ]; then
  echo "Error: could not determine user identity"
  exit 1
fi

if ! command -v cmux &>/dev/null; then
  echo "Error: cmux is required. Install from https://github.com/manaflow-ai/cmux"
  exit 1
fi

session_dir_for() {
  local hash=$(printf '%s' "$1" | md5 -q)
  echo "$BASE_DIR/$hash"
}

case "${1:-}" in
  --stop)
    if [ -n "${2:-}" ]; then
      PEN_FILE="$(cd "$(dirname "$2")" && pwd)/$(basename "$2")"
      SESSION_DIR=$(session_dir_for "$PEN_FILE")
      SURFACE=$(cat "$SESSION_DIR/.surface-id" 2>/dev/null) && cmux browser "$SURFACE" close 2>/dev/null
      rm -rf "$SESSION_DIR"
      echo "Stopped: $PEN_FILE"
    else
      for dir in "$BASE_DIR"/*/; do
        [ -d "$dir" ] || continue
        SURFACE=$(cat "$dir/.surface-id" 2>/dev/null) && cmux browser "$SURFACE" close 2>/dev/null
      done
      rm -rf "$BASE_DIR"/*/
      echo "All sessions stopped"
    fi
    exit 0
    ;;
  --reload)
    if [ -n "${2:-}" ]; then
      PEN_FILE="$(cd "$(dirname "$2")" && pwd)/$(basename "$2")"
      SESSION_DIR=$(session_dir_for "$PEN_FILE")
      SURFACE=$(cat "$SESSION_DIR/.surface-id" 2>/dev/null) || { echo "No session for: $PEN_FILE"; exit 1; }
      cmux browser "$SURFACE" reload 2>/dev/null && echo "Reloaded $SURFACE" || echo "Reload failed"
    else
      for dir in "$BASE_DIR"/*/; do
        [ -d "$dir" ] || continue
        SURFACE=$(cat "$dir/.surface-id" 2>/dev/null) || continue
        cmux browser "$SURFACE" reload 2>/dev/null && echo "Reloaded $SURFACE"
      done
    fi
    exit 0
    ;;
  --list)
    for dir in "$BASE_DIR"/*/; do
      [ -d "$dir" ] || continue
      PEN_PATH=$(cat "$dir/.pen-path" 2>/dev/null) || continue
      echo "$PEN_PATH"
      PDF="$dir/preview.pdf"
      [ -f "$PDF" ] && echo "  pdf: $PDF" || echo "  pdf: (not exported)"
    done
    exit 0
    ;;
  --clean)
    rm -rf "$BASE_DIR"/*/
    echo "Cleaned: $BASE_DIR"
    exit 0
    ;;
  ""|--help|-h)
    echo "pen-preview: Pencil design hot reload for cmux"
    echo ""
    echo "Usage:"
    echo "  pen-preview <file.pen>          Start preview"
    echo "  pen-preview --reload [file.pen]  Reload browser (all if no file)"
    echo "  pen-preview --stop [file.pen]    Stop preview (all if no file)"
    echo "  pen-preview --list               List sessions"
    echo "  pen-preview --clean              Remove all state files"
    exit 0
    ;;
esac

PEN_FILE="$(cd "$(dirname "$1")" && pwd)/$(basename "$1")"

if [ ! -f "$PEN_FILE" ]; then
  echo "Error: File not found: $PEN_FILE"
  exit 1
fi

SESSION_DIR=$(session_dir_for "$PEN_FILE")
mkdir -p "$SESSION_DIR"
echo "$PEN_FILE" > "$SESSION_DIR/.pen-path"

PDF_FILE="$SESSION_DIR/preview.pdf"

if [ -f "$PDF_FILE" ]; then
  RESULT=$(cmux browser open "file://$PDF_FILE" 2>&1)
else
  RESULT=$(cmux browser open "about:blank" 2>&1)
fi

SURFACE=$(echo "$RESULT" | grep -o 'surface:[0-9]*' | head -1)
if [ -n "$SURFACE" ]; then
  echo "$SURFACE" > "$SESSION_DIR/.surface-id"
else
  echo "Error: Could not open cmux browser pane"
  echo "Result: $RESULT"
  rm -rf "$SESSION_DIR"
  exit 1
fi

echo "=== pen-preview ==="
echo "Pen file: $PEN_FILE"
echo "Surface:  $SURFACE"
echo "PDF:      $PDF_FILE"
echo ""
echo "Ready. Claude Code will auto-export + reload after batch_design."
echo "Run 'pen-preview --stop $1' to deactivate."
